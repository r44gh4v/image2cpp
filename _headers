# Cache rules for Cloudflare Pages.
# Fonts are immutable once deployed; cache for 1 year.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# PWA icons and OG image; cache for 1 week.
/assets/*.png
  Cache-Control: public, max-age=604800

# CSS and JS; cache for 1 day (content may change on deploy).
/css/*
  Cache-Control: public, max-age=86400

/js/*
  Cache-Control: public, max-age=86400

# Favicon; cache for 1 week.
/favicon.svg
  Cache-Control: public, max-age=604800

# Manifest; cache for 1 day.
/manifest.json
  Cache-Control: public, max-age=86400
